<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ruoyi.system.mapper.AuditBasisMapper">

    <resultMap id="AuditBasisResult" type="AuditBasis">
        <id     property="id"            column="id"             />
        <result property="category"      column="category"       />
        <result property="title"         column="title"          />
        <result property="content"       column="content"        />
        <result property="issueOrg"      column="issue_org"      />
        <result property="effectiveDate" column="effective_date" />
        <result property="status"        column="status"         />
        <result property="version"       column="version"        />
        <result property="docNumber"     column="doc_number"     />
        <result property="auditScope"    column="audit_scope"    />
        <result property="fundType"      column="fund_type"      />
        <result property="expireDate"    column="expire_date"    />
        <result property="hierarchyLevel" column="hierarchy_level" />
        <result property="createBy"      column="create_by"      />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"      column="update_by"      />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <!-- 查询依据列表（分页 + 条件筛选） -->
    <select id="selectAuditBasisList" parameterType="AuditBasis" resultMap="AuditBasisResult">
        SELECT * FROM audit_basis
        <where>
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
            <if test="title != null and title != ''">
                AND title LIKE '%' || #{title} || '%'
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="issueOrg != null and issueOrg != ''">
                AND issue_org LIKE '%' || #{issueOrg} || '%'
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <!-- 根据ID查询 -->
    <select id="selectAuditBasisById" parameterType="Long" resultMap="AuditBasisResult">
        SELECT * FROM audit_basis WHERE id = #{id}
    </select>

    <!-- 新增依据 -->
    <insert id="insertAuditBasis" parameterType="AuditBasis" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO audit_basis (category, title, content, issue_org, effective_date, status, version,
                                 doc_number, audit_scope, fund_type, expire_date, hierarchy_level,
                                 create_by, create_time, update_time)
        VALUES (#{category}, #{title}, #{content}, #{issueOrg}, #{effectiveDate}::date, #{status}, 1,
                #{docNumber}, #{auditScope}, #{fundType}, #{expireDate}, #{hierarchyLevel},
                #{createBy}, now(), now())
    </insert>

    <!-- 修改依据 -->
    <update id="updateAuditBasis" parameterType="AuditBasis">
        UPDATE audit_basis
        <set>
            <if test="category != null and category != ''">category = #{category},</if>
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="content != null and content != ''">content = #{content},</if>
            <if test="issueOrg != null">issue_org = #{issueOrg},</if>
            <if test="effectiveDate != null">effective_date = #{effectiveDate}::date,</if>
            <if test="status != null">status = #{status},</if>
            <if test="docNumber != null">doc_number = #{docNumber},</if>
            <if test="auditScope != null">audit_scope = #{auditScope},</if>
            <if test="fundType != null">fund_type = #{fundType},</if>
            <if test="expireDate != null">expire_date = #{expireDate},</if>
            <if test="hierarchyLevel != null">hierarchy_level = #{hierarchyLevel},</if>
            version = #{version},
            update_by = #{updateBy},
            update_time = now()
        </set>
        WHERE id = #{id}
    </update>

    <!-- 批量删除 -->
    <delete id="deleteAuditBasisByIds">
        DELETE FROM audit_basis WHERE id IN
        <foreach collection="array" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- 更新生效状态 -->
    <update id="updateAuditBasisStatus">
        UPDATE audit_basis SET status = #{status}, update_time = now() WHERE id = #{id}
    </update>

    <!-- 关键词全文检索 -->
    <select id="searchByKeyword" resultMap="AuditBasisResult">
        SELECT * FROM audit_basis
        WHERE status = 1
        <if test="keyword != null and keyword != ''">
            AND (title LIKE '%' || #{keyword} || '%' OR content LIKE '%' || #{keyword} || '%')
        </if>
        <if test="category != null and category != ''">
            AND category = #{category}
        </if>
        ORDER BY create_time DESC
        LIMIT 20
    </select>

</mapper>
