<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.RiskClueMapper">
    <resultMap id="RiskClueResult" type="RiskClue">
        <id property="id" column="id" />
        <result property="projectId" column="project_id" />
        <result property="clueType" column="clue_type" />
        <result property="content" column="content" />
        <result property="severity" column="severity" />
        <result property="status" column="status" />
        <result property="createTime" column="create_time" />
    </resultMap>
    <select id="selectRiskClueList" resultMap="RiskClueResult">
        SELECT * FROM risk_clue ORDER BY severity DESC, create_time DESC
    </select>
    <select id="selectRiskClueById" resultMap="RiskClueResult">
        SELECT * FROM risk_clue WHERE id = #{id}
    </select>
    <insert id="insertRiskClue" parameterType="RiskClue" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO risk_clue(project_id, clue_type, content, severity, status, create_time)
        VALUES (#{projectId}, #{clueType}, #{content}, #{severity}, 0, now())
    </insert>
    <update id="updateRiskClue" parameterType="RiskClue">
        UPDATE risk_clue SET clue_type=#{clueType}, content=#{content}, severity=#{severity}, status=#{status} WHERE id=#{id}
    </update>
    <delete id="deleteRiskClueByIds">
        DELETE FROM risk_clue WHERE id IN <foreach collection="array" item="id" open="(" separator="," close=")">#{id}</foreach>
    </delete>
</mapper>
