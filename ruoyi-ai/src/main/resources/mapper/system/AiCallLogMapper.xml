<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AiCallLogMapper">
    <resultMap id="AiCallLogResult" type="AiCallLog">
        <id property="id" column="id" />
        <result property="userId" column="user_id" />
        <result property="intent" column="intent" />
        <result property="prompt" column="prompt" />
        <result property="response" column="response" />
        <result property="citedBasisIds" column="cited_basis_ids" />
        <result property="modelProvider" column="model_provider" />
        <result property="tokensUsed" column="tokens_used" />
        <result property="status" column="status" />
        <result property="costTimeMs" column="cost_time_ms" />
        <result property="createTime" column="create_time" />
    </resultMap>
    <select id="selectAiCallLogList" resultMap="AiCallLogResult">
        SELECT * FROM ai_call_log ORDER BY create_time DESC
    </select>
    <select id="selectAiCallLogById" resultMap="AiCallLogResult">
        SELECT * FROM ai_call_log WHERE id = #{id}
    </select>
    <insert id="insertAiCallLog" parameterType="AiCallLog" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_call_log(user_id, intent, prompt, response, cited_basis_ids, model_provider, tokens_used, status, cost_time_ms, create_time)
        VALUES (#{userId}, #{intent}, #{prompt}, #{response}, #{citedBasisIds}, #{modelProvider}, #{tokensUsed}, #{status}, #{costTimeMs}, now())
    </insert>
</mapper>
