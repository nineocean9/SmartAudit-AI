<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ruoyi.system.mapper.AiChatMapper">

    <!-- ==================== 会话 ==================== -->
    <resultMap id="ConversationResult" type="com.ruoyi.system.domain.AiConversation">
        <id     property="id"             column="id"              />
        <result property="title"          column="title"           />
        <result property="userId"         column="user_id"         />
        <result property="model"          column="model"           />
        <result property="status"         column="status"          />
        <result property="workspaceMode"  column="workspace_mode"  />
        <result property="projectId"      column="project_id"      />
        <result property="tempSessionId"  column="temp_session_id" />
        <result property="createTime"     column="create_time"     />
        <result property="updateTime"     column="update_time"     />
    </resultMap>

    <!-- ==================== 消息 ==================== -->
    <resultMap id="MessageResult" type="com.ruoyi.system.domain.AiMessage">
        <id     property="id"             column="id"/>
        <result property="conversationId" column="conversation_id"/>
        <result property="role"           column="role"/>
        <result property="content"        column="content"/>
        <result property="tokens"         column="tokens"/>
        <result property="createTime"     column="create_time"/>
    </resultMap>

    <insert id="insertConversation" parameterType="com.ruoyi.system.domain.AiConversation"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_conversation(title, user_id, model, workspace_mode, project_id, temp_session_id,
                                     status, create_by, create_time, update_time)
        VALUES (#{title}, #{userId}, #{model}, #{workspaceMode}, #{projectId}, #{tempSessionId},
                1, #{createBy}, now(), now())
    </insert>

    <update id="updateConversationTitle">
        UPDATE ai_conversation SET title = #{title}, update_time = now()
        WHERE id = #{id} AND user_id = #{userId}
    </update>

    <update id="deleteConversation">
        UPDATE ai_conversation SET status = 0, update_time = now()
        WHERE id = #{id} AND user_id = #{userId}
    </update>

    <update id="updateConversationContext">
        UPDATE ai_conversation SET
            workspace_mode = #{workspaceMode},
            project_id = #{projectId},
            temp_session_id = #{tempSessionId},
            update_time = now()
        WHERE id = #{id}
    </update>

    <select id="selectConversationsByUserId" resultMap="ConversationResult">
        SELECT * FROM ai_conversation
        WHERE user_id = #{userId} AND status = 1
        ORDER BY update_time DESC
        LIMIT 50
    </select>

    <select id="selectConversationById" resultMap="ConversationResult">
        SELECT * FROM ai_conversation
        WHERE id = #{id} AND user_id = #{userId} AND status = 1
    </select>

    <insert id="insertMessage" parameterType="com.ruoyi.system.domain.AiMessage"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_message(conversation_id, role, content, tokens, create_time)
        VALUES (#{conversationId}, #{role}, #{content}, #{tokens}, now())
    </insert>

    <select id="selectMessagesByConversationId" resultMap="MessageResult">
        SELECT * FROM ai_message
        WHERE conversation_id = #{conversationId}
        ORDER BY id ASC
        LIMIT 100
    </select>

    <delete id="deleteMessagesByConversationId">
        DELETE FROM ai_message WHERE conversation_id = #{conversationId}
    </delete>

</mapper>
