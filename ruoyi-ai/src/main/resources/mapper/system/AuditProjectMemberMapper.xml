<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AuditProjectMemberMapper">
    <resultMap id="Result" type="AuditProjectMember">
        <id property="id" column="id"/><result property="projectId" column="project_id"/>
        <result property="userId" column="user_id"/><result property="userName" column="user_name"/>
        <result property="roleType" column="role_type"/><result property="taskScope" column="task_scope"/>
        <result property="taskDeadline" column="task_deadline"/><result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
    </resultMap>
    <select id="selectByProjectId" resultMap="Result">SELECT * FROM audit_project_member WHERE project_id=#{projectId} ORDER BY role_type, create_time</select>
    <insert id="insert" parameterType="AuditProjectMember" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO audit_project_member(project_id,user_id,user_name,role_type,task_scope,task_deadline,status,create_time)
        VALUES(#{projectId},#{userId},#{userName},#{roleType},#{taskScope},#{taskDeadline}::date,#{status},now())</insert>
    <update id="update" parameterType="AuditProjectMember">UPDATE audit_project_member SET role_type=#{roleType},task_scope=#{taskScope},task_deadline=#{taskDeadline}::date,status=#{status} WHERE id=#{id}</update>
    <delete id="deleteById">DELETE FROM audit_project_member WHERE id=#{id}</delete>
    <select id="selectUserWorkload" resultType="java.util.Map">
        SELECT m.user_name, m.role_type, count(*) as project_count,
               sum(CASE WHEN p.status=1 THEN 1 ELSE 0 END) as active_count
        FROM audit_project_member m JOIN audit_project p ON p.id=m.project_id
        GROUP BY m.user_name, m.role_type ORDER BY project_count DESC</select>
</mapper>
