<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ruoyi.system.mapper.TempWorkspaceMapper">

    <resultMap id="WorkspaceResult" type="com.ruoyi.system.domain.TempWorkspace">
        <id     property="id"          column="id"            />
        <result property="sessionId"   column="session_id"    />
        <result property="userId"      column="user_id"       />
        <result property="fileName"    column="file_name"     />
        <result property="filePath"    column="file_path"     />
        <result property="contentText" column="content_text"  />
        <result property="status"      column="status"        />
        <result property="expireTime"  column="expire_time"   />
        <result property="createTime"  column="create_time"   />
    </resultMap>

    <insert id="insert" parameterType="com.ruoyi.system.domain.TempWorkspace"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO temporary_workspace(session_id, user_id, file_name, file_path,
                                        content_text, status, expire_time, create_time)
        VALUES (#{sessionId}, #{userId}, #{fileName}, #{filePath},
                #{contentText}, 1, #{expireTime}, now())
    </insert>

    <select id="selectBySessionId" resultMap="WorkspaceResult">
        SELECT * FROM temporary_workspace
        WHERE session_id = #{sessionId} AND status = 1
        ORDER BY create_time ASC
    </select>

    <select id="selectById" resultMap="WorkspaceResult">
        SELECT * FROM temporary_workspace WHERE id = #{id}
    </select>

    <update id="destroyBySessionId">
        UPDATE temporary_workspace SET status = 0
        WHERE session_id = #{sessionId}
    </update>

    <delete id="deleteExpired">
        DELETE FROM temporary_workspace
        WHERE expire_time &lt; now() OR status = 0
    </delete>

</mapper>
