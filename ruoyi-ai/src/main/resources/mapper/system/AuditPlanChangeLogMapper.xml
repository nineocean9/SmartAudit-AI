<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AuditPlanChangeLogMapper">
    <resultMap id="Result" type="AuditPlanChangeLog">
        <id property="id" column="id"/><result property="planId" column="plan_id"/>
        <result property="changeType" column="change_type"/><result property="beforeJson" column="before_json"/>
        <result property="afterJson" column="after_json"/><result property="changeReason" column="change_reason"/>
        <result property="changeBy" column="change_by"/><result property="changeTime" column="change_time"/>
    </resultMap>
    <select id="selectByPlanId" resultMap="Result">SELECT * FROM audit_plan_change_log WHERE plan_id=#{planId} ORDER BY change_time DESC</select>
    <insert id="insert" parameterType="AuditPlanChangeLog" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO audit_plan_change_log(plan_id,change_type,before_json,after_json,change_reason,change_by,change_time)
        VALUES(#{planId},#{changeType},#{beforeJson},#{afterJson},#{changeReason},#{changeBy},now())</insert>
</mapper>
